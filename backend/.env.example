# IPFS Configuration
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_PROTOCOL=http
IPFS_API_PATH=/api/v0
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# IPFS Upload Configuration
IPFS_MAX_FILE_SIZE=104857600
IPFS_CHUNK_SIZE=1048576
IPFS_AUTO_PIN=true
IPFS_PIN_TIMEOUT=30000

# IPFS Caching
IPFS_ENABLE_CACHE=true
IPFS_CACHE_TIMEOUT=3600000

# IPFS Retry Configuration
IPFS_MAX_RETRIES=3
IPFS_RETRY_DELAY=1000

# IPFS Authentication (optional)
IPFS_AUTH_ENABLED=false
IPFS_AUTH_USERNAME=
IPFS_AUTH_PASSWORD=
IPFS_AUTH_TOKEN=

# IPFS Metadata Configuration
IPFS_INCLUDE_TIMESTAMP=true
IPFS_INCLUDE_UPLOADER=true
IPFS_INCLUDE_CONTENT_TYPE=true
IPFS_INCLUDE_FILE_SIZE=true

# JWT Configuration (for IPFS authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=3001
NODE_ENV=development
